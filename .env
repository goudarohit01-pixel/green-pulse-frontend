# ── Green Pulse Frontend Environment Variables ──────────────
# Vite requires VITE_ prefix for all env variables
# Access in code via: import.meta.env.VITE_API_BASE_URL

# Backend API base URL
VITE_API_BASE_URL=http://localhost:8080/api

# App name (used in page titles)
VITE_APP_NAME=Green Pulse

# National average CO2 per day (kg) — used for comparison widget
VITE_NATIONAL_AVG_KG=23